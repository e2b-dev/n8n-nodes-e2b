{
  "compilerOptions": {
    "declaration": true,
    "esModuleInterop": true,
    "lib": ["es2022"],
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "dist",
    "resolveJsonModule": true,
    "rootDir": ".",
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "es2022",
    "types": ["node"]
  },
  "include": ["credentials/**/*.ts", "nodes/**/*.ts", "nodes/**/*.json", "package.json"],
  "exclude": ["dist", "node_modules", "**/*.test.ts"]
}
